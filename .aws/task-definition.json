{
  "containerDefinitions": [
    {
      "name": "db-container",
      "image": "199014867669.dkr.ecr.us-east-1.amazonaws.com/tienda-db:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3306,
          "hostPort": 3306,
          "protocol": "tcp",
          "name": "db-3306-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "MYSQL_DATABASE", "value": "tienda_perritos" },
        { "name": "MYSQL_ROOT_PASSWORD", "value": "admin123" }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mysql-storage",
          "containerPath": "/var/lib/mysql",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tienda-db-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "tienda-db-task",
  "taskRoleArn": "arn:aws:iam::199014867669:role/LabRole",
  "executionRoleArn": "arn:aws:iam::199014867669:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "512",
  "memory": "1024",
  "volumes": [
    {
      "name": "mysql-storage",
      "efsVolumeConfiguration": {
        "fileSystemId": "CAMBIAR_POR_ID_DE_EFS",
        "transitEncryption": "ENABLED"
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
